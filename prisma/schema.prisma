// TechC MVP - Prisma Schema
// PostgreSQL + Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  STUDENT
  EMPLOYER
  ADMIN
}

enum CareerPath {
  WEB_DEV
  AI_ML
  CYBERSECURITY
  EMBEDDED_SYSTEMS
  DATA_SCIENCE
  UI_UX
  DEVOPS
}

enum SubmissionStatus {
  PENDING
  AUTO_CHECKED
  AI_REVIEWED
  MENTOR_APPROVED
  REJECTED
}

enum JobType {
  INTERNSHIP
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum ApplicationStatus {
  APPLIED
  REVIEWED
  SHORTLISTED
  REJECTED
  HIRED
}

// ─────────────────────────────────────────
// USERS
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  role          Role
  name          String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  studentProfile  StudentProfile?
  employerProfile EmployerProfile?
}

model StudentProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  username        String      @unique
  university      String
  department      String      // CSE or EEE
  graduationYear  Int
  careerPath      CareerPath?
  bio             String?
  githubUrl       String?
  linkedinUrl     String?
  portfolioUrl    String?     // auto-generated: techc.app/u/username
  skills          String[]    // e.g. ["React", "Node.js"]
  isPublic        Boolean     @default(true)

  submissions     ProjectSubmission[]
  applications    JobApplication[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model EmployerProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName     String
  website         String?
  industry        String
  size            String    // e.g. "1-10", "11-50", "51-200"
  description     String?
  location        String    // e.g. "Dhaka, Bangladesh"
  isVerified      Boolean   @default(false)

  jobs            Job[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─────────────────────────────────────────
// CAREER PATHS & PROJECTS
// ─────────────────────────────────────────

model CareerRoadmap {
  id          String      @id @default(cuid())
  path        CareerPath  @unique
  title       String
  description String
  skills      String[]
  projects    RoadmapProject[]
}

model RoadmapProject {
  id          String        @id @default(cuid())
  roadmapId   String
  roadmap     CareerRoadmap @relation(fields: [roadmapId], references: [id])

  title       String
  description String
  difficulty  String        // "junior" | "mid" | "senior"
  skills      String[]
  githubTemplate String?
  order       Int

  submissions ProjectSubmission[]
}

// ─────────────────────────────────────────
// PROJECT SUBMISSIONS & VALIDATION
// ─────────────────────────────────────────

model ProjectSubmission {
  id              String            @id @default(cuid())
  studentId       String
  student         StudentProfile    @relation(fields: [studentId], references: [id])
  projectId       String
  project         RoadmapProject    @relation(fields: [projectId], references: [id])

  githubUrl       String
  description     String?
  status          SubmissionStatus  @default(PENDING)

  // Validation layers
  autoCheckScore  Int?              // 0-100
  autoCheckNotes  String?
  aiReviewScore   Int?              // 0-100
  aiReviewNotes   String?
  mentorNotes     String?
  mentorApprovedAt DateTime?

  badgeUid        String?           @unique // public verification UID

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

// ─────────────────────────────────────────
// JOBS & APPLICATIONS
// ─────────────────────────────────────────

model Job {
  id              String          @id @default(cuid())
  employerId      String
  employer        EmployerProfile @relation(fields: [employerId], references: [id])

  title           String
  description     String
  requirements    String[]
  careerPath      CareerPath
  jobType         JobType
  salaryRange     String?         // e.g. "15,000–25,000 BDT"
  location        String          // "Dhaka" | "Remote" | "Hybrid"
  deadline        DateTime?
  isActive        Boolean         @default(true)

  applications    JobApplication[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model JobApplication {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id])
  studentId   String
  student     StudentProfile    @relation(fields: [studentId], references: [id])

  coverNote   String?
  status      ApplicationStatus @default(APPLIED)

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, studentId])
}
